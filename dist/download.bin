<section class="py-5">
    <div class="container" style="max-width: 480px;">
        <div class="card border-0 shadow-lg">
            <div class="card-body p-4 p-lg-5">
                <h1 class="h3 mb-2">Sign In</h1>
                <p class="text-secondary mb-4">Use your LMS username and password.</p>

                

                <form method="post" data-loading-submit>
                    <input type="hidden" name="csrfmiddlewaretoken" value="FdnpZsRYgpsC9u0lXPpaNeT1kXC4nUNWUfkMV3CXgnSl6LP4yv5PNjZBXqcPnisA">
                    <div class="mb-3">
                        <label class="form-label" for="id_username">Username</label>
                        <input type="text" name="username" class="form-control" id="id_username" required autofocus value="">
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="id_password">Password</label>
                        <input type="password" name="password" class="form-control" id="id_password" required>
                    </div>
                    
                    <input type="hidden" name="next" value="/attendances/report/download/">
                    
                    <button type="submit" class="btn btn-primary w-100">Login</button>
                </form>

                <div class="mt-3 small text-secondary">
                    Admin user? <a href="/admin/login/">Open admin login</a>
                </div>
            </div>
        </div>
    </div>
</section>

	</main>

	<footer class="site-footer mt-auto">
		<div class="container py-5">
			<div class="row g-4">
				<div class="col-lg-6">
					<h2 class="footer-brand mb-3">
						<span class="brand-icon" aria-hidden="true"><i class="fa-solid fa-graduation-cap"></i></span>
						LMS
