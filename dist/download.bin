	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"
		integrity="sha384-7qAoOXltbVP82dhxHAUje59V5r2YsVfBafyUDxEdApLPmcdhBPg1DKg1ERo0BZlK"
		crossorigin="anonymous"></script>
	<script src="/static/js/scripts.js"></script>
	<script>
		document.querySelectorAll('form[data-loading-submit]').forEach((form) => {
			form.addEventListener('submit', () => {
				const submitButton = form.querySelector('button[type="submit"]');
				if (!submitButton) {
					return;
				}
				submitButton.disabled = true;
				submitButton.dataset.originalText = submitButton.textContent;
				submitButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>Processing...';
			});
		});

		const autoDismissMessages = document.querySelectorAll('.alert.alert-success');
		autoDismissMessages.forEach((message) => {
			window.setTimeout(() => {
				const alert = bootstrap.Alert.getOrCreateInstance(message);
				alert.close();
			}, 4000);
		});

		async function desktopDownload(payload) {
			if (!window.pywebview || !window.pywebview.api || !window.pywebview.api.download_request) {
				return false;
			}

			const response = await window.pywebview.api.download_request({
				...payload,
				cookies: document.cookie,
			});

			if (!response || !response.ok) {
				if (!response || !response.cancelled) {
					alert((response && response.error) ? response.error : 'Download failed.');
				}
				return true;
			}

			return true;
		}

		document.addEventListener('click', async (event) => {
			const link = event.target.closest('a[href]');
			if (!link) {
				return;
			}

			const href = link.getAttribute('href') || '';
			const isDownloadLink = link.hasAttribute('download') || href.includes('/download/') || href.includes('import-template');
			if (!isDownloadLink) {
				return;
			}

			event.preventDefault();
			await desktopDownload({
				method: 'GET',
				path: href,
				params: [],
			});
		});

		document.querySelectorAll('form[action*="/download/"]').forEach((form) => {
			form.addEventListener('submit', async (event) => {
				if (!(window.pywebview && window.pywebview.api && window.pywebview.api.download_request)) {
					return;
				}

				event.preventDefault();
				const data = new FormData(form);
				const submitter = event.submitter || document.activeElement;
				if (submitter && submitter.name) {
					data.set(submitter.name, submitter.value || '');
				}

				await desktopDownload({
					method: (form.method || 'POST').toUpperCase(),
					path: form.getAttribute('action') || window.location.pathname,
					params: Array.from(data.entries()),
				});
			});
		});
	</script>
	
	
</body>

</html>
